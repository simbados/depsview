{
  "name": "depsview",
  "version": "1.0.0",
  "type": "module",
  "description": "List all dependencies and subdependencies of a Python project",
  "bin": {
    "depsview": "./src/main.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "npm run prepare && node --test",
    "build": "rm web/src && cp -r src web/src",
    "prepare": "rm -rf web/src && ln -s ../src web/src"
  }
}
